<?xml version="1.0" encoding="utf-8"?>
<!--
  Optimized Network Security Configuration for Campus Mobile (Android)
  Ensures maximum reliability in production release builds.
-->
<network-security-config>
    <!-- Base config: Allow HTTPS with system and user certificates -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Explicit domains for development environments -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- Production Heroku backend — enforce HTTPS, trust system certs -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">smart-campus-access-1cc4e15f5ba0.herokuapp.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>

