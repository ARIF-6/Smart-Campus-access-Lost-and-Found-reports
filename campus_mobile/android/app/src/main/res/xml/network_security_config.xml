<?xml version="1.0" encoding="utf-8"?>
<!--
  Optimized Network Security Configuration for Campus Mobile (Android)
  Ensures maximum reliability in production release builds.
-->
<network-security-config>
    <!-- Base config: Allow HTTPS with system and user certificates, plus fallback to cleartext for reliability on diverse networks -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Explicits for development environments and production Render domain -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="true">smart-campus-access-lost-and-found-dbgg.onrender.com</domain>
    </domain-config>
</network-security-config>
